# sam-os environment variables
# Copy this file: cp .env.example .env
# Then edit .env with your real values
# IMPORTANT: .env is gitignored. NEVER commit it.

# ─── Database ────────────────────────────────────────────────────────────

# Host path to the SQLite directory (used by docker-compose for bind mount)
# Default on homelab: /home/server/data
SAMOS_DB_HOST_PATH=/home/server/data

# Path to the SQLite file INSIDE the container (do not change unless using a custom layout)
SAMOS_DB_PATH=/data/schedule.db

# ─── Backup Service (Neon Postgres) ──────────────────────────────────────

# Neon connection string. Get from neon.tech dashboard → Connection Details
# Recommended: UNPOOLED connection for single-client nightly jobs (lower overhead)
#
# Example: postgresql://neondb_owner:<password>@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
BACKUP_PG_DSN=

# Alternative: build from individual vars (used as fallback if BACKUP_PG_DSN unset)
# BACKUP_PG_HOST=ep-xxx-pooler.us-east-1.aws.neon.tech
# BACKUP_PG_PORT=5432
# BACKUP_PG_DB=neondb
# BACKUP_PG_USER=neondb_owner
# BACKUP_PG_PASSWORD=
# BACKUP_PG_SSLMODE=require

# ─── Calendar Integration ────────────────────────────────────────────────

# Set to 1 to skip all iCloud CalDAV reads/writes (useful for maintenance or no creds)
SAMOS_CALENDAR_OFFLINE=0

# Name of the target iCloud calendar to sync today's schedule into
SAMOS_CALENDAR=sam-os

# iCloud credentials live in ~/.hermes/.env:
#   ICLOUD_USERNAME=swayam.joshi1903@gmail.com
#   ICLOUD_APP_PASSWORD=          # format: xxxx-xxxx-xxxx-xxxx

# ─── Hermes / MCP ────────────────────────────────────────────────────────

# Path to the Hermes home directory (used to locate ~/.hermes/.env for iCloud)
HERMES_HOME=/home/server/.hermes

# ─── Misc ────────────────────────────────────────────────────────────────

# Timezone for logs and cron triggers
TZ=America/Toronto

# Ensure Python stdout/stderr use UTF-8 (safe for emoji output on all platforms)
PYTHONIOENCODING=utf-8
